# =========================================================================
# APPLICATION CONFIGURATION
# =========================================================================
APP_NAME="SSR Portfolio"
APP_DESCRIPTION="Premium animated portfolio built with Nuxt 4"
APP_URL="http://localhost:3000"
APP_ENV="development"
APP_AUTHOR=""

# =========================================================================
# SEO CONFIGURATION (Runtime Public Config)
# =========================================================================
NUXT_PUBLIC_SITE_NAME=""
NUXT_PUBLIC_SITE_DESCRIPTION=""
NUXT_PUBLIC_SITE_KEYWORDS=""
NUXT_PUBLIC_SITE_LANGUAGE="id"
NUXT_PUBLIC_SITE_LOCALE="id_ID"
NUXT_PUBLIC_SITE_IMAGE=""

# =========================================================================
# PERSONAL IDENTITY
# =========================================================================
NUXT_PUBLIC_FULL_NAME=""
NUXT_PUBLIC_NICKNAME=""
NUXT_PUBLIC_TITLE=""
NUXT_PUBLIC_TAGLINE=""
NUXT_PUBLIC_LOCATION=""
NUXT_PUBLIC_EMAIL=""
NUXT_PUBLIC_PHONE=""
NUXT_PUBLIC_WEBSITE=""

# =========================================================================
# SOCIAL LINKS
# =========================================================================
NUXT_PUBLIC_GITHUB=""
NUXT_PUBLIC_GITLAB=""
NUXT_PUBLIC_LINKEDIN=""
NUXT_PUBLIC_INSTAGRAM=""
NUXT_PUBLIC_X=""
NUXT_PUBLIC_YOUTUBE=""
NUXT_PUBLIC_DISCORD=""
NUXT_PUBLIC_TELEGRAM=""
NUXT_PUBLIC_FACEBOOK=""

# =========================================================================
# ANALYTICS
# =========================================================================
NUXT_PUBLIC_GA_ID=""
NUXT_PUBLIC_GTM_ID=""
NUXT_PUBLIC_UMAMI_ID=""
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# =========================================================================
# THEME CONFIGURATION
# =========================================================================
NUXT_PUBLIC_DEFAULT_THEME="dark"
NUXT_PUBLIC_ACCENT_COLOR="#6AD3F7"
NUXT_PUBLIC_ENABLE_CURSOR="true"
NUXT_PUBLIC_ENABLE_PRELOADER="true"
NUXT_PUBLIC_ENABLE_SOUND="false"
NUXT_PUBLIC_ENABLE_ANIMATION="true"
NUXT_PUBLIC_ENABLE_REDUCED_MOTION="true"

# =========================================================================
# FEATURE FLAGS
# =========================================================================
NUXT_PUBLIC_ENABLE_BLOG="false"
NUXT_PUBLIC_ENABLE_PROJECTS="true"
NUXT_PUBLIC_ENABLE_TESTIMONIALS="false"
NUXT_PUBLIC_ENABLE_STATS="true"
NUXT_PUBLIC_ENABLE_CONTACT_FORM="true"
NUXT_PUBLIC_ENABLE_OPEN_SOURCE="true"
NUXT_PUBLIC_ENABLE_EXPERIENCE="true"

# =========================================================================
# CONTACT DETAILS
# =========================================================================
NUXT_PUBLIC_CONTACT_EMAIL=""
NUXT_PUBLIC_CONTACT_PHONE=""
NUXT_PUBLIC_CONTACT_WHATSAPP=""

# =========================================================================
# API CONFIGURATION
# =========================================================================
NUXT_PUBLIC_API_BASE=""
NUXT_PUBLIC_API_VERSION="v1"
